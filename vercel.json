{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm install --save-dev @types/node && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://barberbooker.onrender.com"
  }
}

{
  "version": 2,
  "buildCommand": "npm install && npm install --save-dev tailwindcss postcss autoprefixer @types/node && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "root": "client",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://barberbooker.onrender.com"
  }
}
